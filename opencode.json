{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "explore": { "disable": true },
    "general": { "disable": true }
  },
  "mcp": {
    "codegraph": {
      "enabled": true,
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ]
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "plugin": [
    "oh-my-opencode-slim"
  ]
}
